# Telegram Casino Bot Environment Variables

# Get from @BotFather
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Server port
PORT=3000

# Your deployed WebApp URL (https://your-domain.com)
WEBAPP_URL=http://localhost:3000

# Admin password for web panel
ADMIN_PASSWORD=admin123

# Admin Telegram IDs (comma separated) - for admin bot commands
ADMIN_IDS=
